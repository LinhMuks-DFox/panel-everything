# Panel Everything — 环境变量示例。复制为 .env 后按需修改。
# 配置项前缀统一为 PANEL_(由 TASK-005 的 pydantic-settings 加载)。

# --- 基础 ---
PANEL_DB_PATH=/data/panel.db
PANEL_LOG_LEVEL=info
PANEL_PORT=8080

# --- 采集器 ---
# stale 阈值(秒):采集距今超过此值视为数据陈旧(TASK-003/004 使用)
PANEL_STALE_THRESHOLD_SECONDS=180

# --- 凭证目录(只读挂载,TASK-005) ---
# docker-compose.yml 中配置: - ./secrets:/secrets:ro
PANEL_SECRETS_DIR=/secrets

# --- Azure 只读 Service Principal (ARCH-002 / TASK-019) ---
# 由 `az ad sp create-for-rbac --name panel-everything-reader --role Reader \
#   --scopes /subscriptions/<sub>/resourceGroups/rg-mux-a100` 创建(资源组级最小权限)。
# 命令输出: tenant→TENANT_ID, appId→CLIENT_ID, password→写入 secret 文件。
# 四项缺任一则 AzureVmCollector 被禁用(register 跳过并 warning)。
# 详见 docs/deployment/DEPLOY.md §1。
# PANEL_AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx        # 命令输出 tenant
# PANEL_AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx        # 命令输出 appId
# PANEL_AZURE_SUBSCRIPTION_ID=d071b64b-e5d3-4b61-9cc8-032d37c7ccb9 # 订阅 ID(固定)
# 凭证按"路径引用"注入,不存明文!password 写入 ./secrets/azure_client_secret,
# 由 docker-compose 以 ./secrets:/secrets:ro 只读挂载;此处填容器内文件路径:
# PANEL_AZURE_CLIENT_SECRET_FILE=/secrets/azure_client_secret

# --- GPU 节点 SSH (ARCH-002) ---
# 私钥(~/.ssh/id_ed25519)复制到 ./secrets/id_ed25519,只读挂入容器 /secrets/id_ed25519。
# 每台服务器注册时 ssh_key_path 也指向该路径。known_hosts=None(StrictHostKeyChecking=no,
# 内网 Tailscale 隔离下首期取舍,见 DEPLOY.md §3)。
# PANEL_SSH_KEY_PATH=/secrets/id_ed25519

# --- AI 用量摄取 (ARCH-004 / TASK-030) ---
# POST /api/ingest/* 的 Bearer token。留空=不鉴权(任意请求都接受);
# 设值则工作站 Reporter 上报时需带 Authorization: Bearer <token>。
# PANEL_INGEST_TOKEN=

# --- 历史数据保留 (ARCH-001 Addendum / TASK-040) ---
# metric_history 中早于此天数的行由每日 retention job 清理。默认 30。
# PANEL_HISTORY_RETENTION_DAYS=30

# --- Tailscale (ARCH-003) ---
# PANEL_TAILSCALE_SOCKET=/var/run/tailscale/tailscaled.sock
