# Panel Everything — 环境变量示例。复制为 .env 后按需修改。
# 配置项前缀统一为 PANEL_(由 TASK-005 的 pydantic-settings 加载)。

# --- 基础 ---
PANEL_DB_PATH=/data/panel.db
PANEL_LOG_LEVEL=info
PANEL_PORT=8080

# --- 采集器 ---
# stale 阈值(秒):采集距今超过此值视为数据陈旧(TASK-003/004 使用)
PANEL_STALE_THRESHOLD_SECONDS=180

# --- 凭证目录(只读挂载,TASK-005) ---
# docker-compose.yml 中配置: - ./secrets:/secrets:ro
PANEL_SECRETS_DIR=/secrets

# --- Azure / GPU / Tailscale / AI 额度等模块配置 ---
# Azure (ARCH-002):
# PANEL_AZURE_TENANT_ID=
# PANEL_AZURE_CLIENT_ID=
# 凭证路径引用(不存明文!文件由 ./secrets/azure_client_secret 只读挂载):
# PANEL_AZURE_CLIENT_SECRET_FILE=/secrets/azure_client_secret

# GPU 节点 SSH (ARCH-002):
# PANEL_SSH_KEY_PATH=/secrets/id_ed25519

# Tailscale (ARCH-003):
# PANEL_TAILSCALE_SOCKET=/var/run/tailscale/tailscaled.sock
