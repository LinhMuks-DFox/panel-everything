# Panel Everything — 工作站 Reporter 配置示例
# 复制到 ~/.config/panel-reporter/env 并按需修改：
#   mkdir -p ~/.config/panel-reporter
#   cp reporter.example.env ~/.config/panel-reporter/env
#
# 格式：KEY=VALUE，每行一项，# 开头为注释。
# 进程环境变量同名时优先级高于本文件。

# ---------------------------------------------------------------------------
# 面板（必填）
# ---------------------------------------------------------------------------
# 面板地址：树莓派的 tailscale IP 或 hostname（含端口）。
PANEL_URL=http://100.x.x.x:8000

# 可选：摄取端点 Bearer token（对应面板 settings.ingest_token）。
# 留空则不发 Authorization 头（tailnet 内单用户默认无需鉴权）。
INGEST_TOKEN=

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Codex（MVP 数据源，最稳）
# ---------------------------------------------------------------------------
# Codex 根目录（默认 ~/.codex）。脚本会扫 sessions/ 下的 rollout-*.jsonl，
# 取最近修改文件里最后一条含 rate_limits 的行。
CODEX_DIR=~/.codex

# ---------------------------------------------------------------------------
# Claude Code（本地 jsonl 滑动窗口）
# ---------------------------------------------------------------------------
# Claude Code 数据目录（默认 ~/.claude/projects）。
CLAUDE_PROJECTS_DIR=~/.claude/projects

# Claude Code token 窗口上限（选填）。
# Anthropic 无公开个人订阅额度 API，此值需用户自行估算填入；
# 不填则仍上报 used_tokens，但 used_percent 为空。
CLAUDE_LIMIT_TOKENS=

# --- 可选 OAuth 回退（实验性，未官方文档化，可能随时失效）---
# 警告：CLAUDE_SESSION_TOKEN 为浏览器会话凭证，有效期有限，需定期更新；
# 仅在工作站本地读取，绝不上报到面板。日志中会脱敏（仅前 8 位明文）。
# 留空则不尝试 OAuth，纯用本地 jsonl。
CLAUDE_SESSION_TOKEN=
CLAUDE_ORG_ID=

# ---------------------------------------------------------------------------
# ChatGPT（降级：手动输入）
# ---------------------------------------------------------------------------
# 手动维护的额度文件路径（默认 ~/.panel_reporter/chatgpt.json）。
# 文件不存在则跳过该 source。文件格式见 README。
CHATGPT_JSON=~/.panel_reporter/chatgpt.json
