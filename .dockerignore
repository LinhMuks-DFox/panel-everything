# 版本控制 / IDE
.git
.gitignore
.github

# Python 缓存与虚拟环境
__pycache__
*.py[cod]
*.egg-info
.venv
venv
.pytest_cache
.ruff_cache
.mypy_cache
.coverage
htmlcov

# 测试(运行时镜像不需要)
tests

